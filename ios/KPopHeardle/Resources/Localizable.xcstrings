    "catalog.unavailable.title" : {
      "comment" : "Shown when catalog cannot be loaded (remote + bundled both failed).",
      "extractionState" : "manual",
      "localizations" : {
        "en"     : { "stringUnit" : { "state" : "translated", "value" : "Catalog unavailable" } },
        "ko"     : { "stringUnit" : { "state" : "translated", "value" : "카탈로그를 불러올 수 없습니다" } },
