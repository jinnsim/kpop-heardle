    "onboarding.p3.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en"     : { "stringUnit" : { "state" : "translated", "value" : "Build a streak with the global puzzle and your favorite group's daily. We'll remind you just after midnight." } },
        "ko"     : { "stringUnit" : { "state" : "translated", "value" : "글로벌 데일리와 좋아하는 그룹 데일리로 스트릭을 쌓으세요. 자정 직후에 알림이 갑니다." } },
        "ja"     : { "stringUnit" : { "state" : "translated", "value" : "グローバルデイリーと推しグループのデイリーで連勝を伸ばそう。深夜 0 時すぎにお知らせします。" } },
        "zh-Hans": { "stringUnit" : { "state" : "translated", "value" : "通过全球每日和心爱团体的每日,累积连胜。我们会在午夜后稍作提醒。" } },
        "zh-Hant": { "stringUnit" : { "state" : "translated", "value" : "透過全球每日和心愛團體的每日,累積連勝。我們會在午夜後稍作提醒。" } },
        "es"     : { "stringUnit" : { "state" : "translated", "value" : "Construye una racha con el reto global y el diario de tu grupo favorito. Te recordaremos justo después de medianoche." } },
        "pt-BR"  : { "stringUnit" : { "state" : "translated", "value" : "Construa uma sequência com o desafio global e o diário do seu grupo favorito. Avisamos logo após meia-noite." } },
        "id"     : { "stringUnit" : { "state" : "translated", "value" : "Bangun streak dengan teka-teki global dan harian grup favoritmu. Kami ingatkan sesudah tengah malam." } },
        "th"     : { "stringUnit" : { "state" : "translated", "value" : "สร้างสตรีคด้วยเพลงประจำวันส่วนกลางและกลุ่มโปรดของคุณ เราจะแจ้งเตือนหลังเที่ยงคืน" } },
        "vi"     : { "stringUnit" : { "state" : "translated", "value" : "Xây dựng chuỗi với câu đố toàn cầu và nhóm yêu thích của bạn. Chúng tôi sẽ nhắc bạn ngay sau nửa đêm." } },
        "fil"    : { "stringUnit" : { "state" : "translated", "value" : "Magbuo ng streak sa global puzzle at sa daily ng paborito mong grupo. Magpapaalala kami pagkatapos ng hatinggabi." } },
        "ms"     : { "stringUnit" : { "state" : "translated", "value" : "Bina streak dengan teka-teki global dan harian kumpulan kegemaran anda. Kami akan ingatkan sebaik selepas tengah malam." } },
        "hi"     : { "stringUnit" : { "state" : "translated", "value" : "वैश्विक पहेली और अपने पसंदीदा ग्रुप के दैनिक से स्ट्रीक बनाएँ। हम आधी रात के बाद आपको याद दिलाएँगे।" } }
      }
    },
