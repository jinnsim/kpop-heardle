    "onboarding.p1.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en"     : { "stringUnit" : { "state" : "translated", "value" : "Each day you get one K-pop preview. Listen and guess the song + artist before your six attempts run out." } },
        "ko"     : { "stringUnit" : { "state" : "translated", "value" : "매일 K-pop 한 곡의 미리듣기가 주어집니다. 6번 안에 곡명과 아티스트를 맞춰보세요." } },
        "ja"     : { "stringUnit" : { "state" : "translated", "value" : "毎日 K-POP のプレビューが 1 つ。6 回以内に曲名とアーティストを当てましょう。" } },
        "zh-Hans": { "stringUnit" : { "state" : "translated", "value" : "每天给你一段 K-pop 试听。在 6 次机会内猜出歌曲和艺人。" } },
        "zh-Hant": { "stringUnit" : { "state" : "translated", "value" : "每天給你一段 K-pop 試聽。在 6 次機會內猜出歌曲和藝人。" } },
        "es"     : { "stringUnit" : { "state" : "translated", "value" : "Cada día tienes una vista previa de K-pop. Adivina la canción y el artista en 6 intentos." } },
        "pt-BR"  : { "stringUnit" : { "state" : "translated", "value" : "Todo dia você ouve uma prévia de K-pop. Adivinhe a música e o artista em 6 tentativas." } },
        "id"     : { "stringUnit" : { "state" : "translated", "value" : "Setiap hari dapat satu pratinjau K-pop. Tebak lagu dan artis dalam 6 percobaan." } },
        "th"     : { "stringUnit" : { "state" : "translated", "value" : "ทุกวันมีตัวอย่างเพลง K-pop 1 เพลง ทายชื่อเพลงและศิลปินภายใน 6 ครั้ง" } },
        "vi"     : { "stringUnit" : { "state" : "translated", "value" : "Mỗi ngày một đoạn nhạc K-pop. Đoán bài hát và nghệ sĩ trong 6 lượt." } },
        "fil"    : { "stringUnit" : { "state" : "translated", "value" : "Bawat araw, isang K-pop preview. Hulaan ang kanta at artist sa 6 na pagkakataon." } },
        "ms"     : { "stringUnit" : { "state" : "translated", "value" : "Setiap hari satu pratonton K-pop. Teka lagu dan artis dalam 6 cubaan." } },
        "hi"     : { "stringUnit" : { "state" : "translated", "value" : "रोज़ एक K-pop प्रीव्यू मिलता है। 6 प्रयासों में गाना और कलाकार अनुमान लगाएँ।" } }
      }
    },
    "onboarding.p2.title" : {
      "extractionState" : "manual",
