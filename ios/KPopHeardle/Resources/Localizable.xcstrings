        "es"     : { "stringUnit" : { "state" : "translated", "value" : "Las vistas previas de audio son provistas por Apple iTunes. K-Pop Heardle no está afiliado con Apple, Spotify o ningún sello de K-pop." } },
        "pt-BR"  : { "stringUnit" : { "state" : "translated", "value" : "As prévias de áudio são fornecidas pelo Apple iTunes. O K-Pop Heardle não tem afiliação com Apple, Spotify ou qualquer gravadora de K-pop." } },
        "id"     : { "stringUnit" : { "state" : "translated", "value" : "Pratinjau audio disediakan oleh Apple iTunes. K-Pop Heardle tidak berafiliasi dengan Apple, Spotify, atau label K-pop mana pun." } },
        "th"     : { "stringUnit" : { "state" : "translated", "value" : "ตัวอย่างเสียงให้บริการโดย Apple iTunes K-Pop Heardle ไม่มีความเกี่ยวข้องกับ Apple, Spotify หรือค่าย K-pop ใดๆ" } },
        "vi"     : { "stringUnit" : { "state" : "translated", "value" : "Bản nghe thử do Apple iTunes cung cấp. K-Pop Heardle không có liên kết với Apple, Spotify hay bất kỳ hãng đĩa K-pop nào." } },
        "fil"    : { "stringUnit" : { "state" : "translated", "value" : "Ang audio previews ay galing sa Apple iTunes. Ang K-Pop Heardle ay hindi affiliated sa Apple, Spotify, o anumang K-pop label." } },
        "ms"     : { "stringUnit" : { "state" : "translated", "value" : "Pratonton audio disediakan oleh Apple iTunes. K-Pop Heardle tidak bergabung dengan Apple, Spotify atau mana-mana label K-pop." } },
        "hi"     : { "stringUnit" : { "state" : "translated", "value" : "ऑडियो प्रीव्यू Apple iTunes द्वारा प्रदान किए गए हैं। K-Pop Heardle Apple, Spotify या किसी K-pop लेबल से संबद्ध नहीं है।" } }
