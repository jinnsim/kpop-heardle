    "notif.daily.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en"     : { "stringUnit" : { "state" : "translated", "value" : "Keep your streak alive — guess today's song." } },
        "ko"     : { "stringUnit" : { "state" : "translated", "value" : "스트릭을 이어가세요 — 오늘의 곡을 맞춰보세요." } },
        "ja"     : { "stringUnit" : { "state" : "translated", "value" : "連勝を続けよう — 今日の曲を当ててください。" } },
        "zh-Hans": { "stringUnit" : { "state" : "translated", "value" : "保持你的连胜——猜出今日的歌曲。" } },
        "zh-Hant": { "stringUnit" : { "state" : "translated", "value" : "保持你的連勝 — 猜出今日的歌曲。" } },
        "es"     : { "stringUnit" : { "state" : "translated", "value" : "Mantén tu racha — adivina la canción de hoy." } },
        "pt-BR"  : { "stringUnit" : { "state" : "translated", "value" : "Mantenha sua sequência — adivinhe a música de hoje." } },
        "id"     : { "stringUnit" : { "state" : "translated", "value" : "Pertahankan streak — tebak lagu hari ini." } },
        "th"     : { "stringUnit" : { "state" : "translated", "value" : "รักษาสตรีคของคุณ — ทายเพลงประจำวันนี้" } },
        "vi"     : { "stringUnit" : { "state" : "translated", "value" : "Giữ chuỗi của bạn — đoán bài hát hôm nay." } },
        "fil"    : { "stringUnit" : { "state" : "translated", "value" : "Panatilihin ang streak — hulaan ang kanta ngayon." } },
        "ms"     : { "stringUnit" : { "state" : "translated", "value" : "Kekalkan streak anda — teka lagu hari ini." } },
        "hi"     : { "stringUnit" : { "state" : "translated", "value" : "अपनी स्ट्रीक बनाए रखें — आज का गाना अनुमान लगाएँ।" } }
      }
    },
    "onboarding.p1.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en"     : { "stringUnit" : { "state" : "translated", "value" : "Hear it. Guess it." } },
        "ko"     : { "stringUnit" : { "state" : "translated", "value" : "듣고, 맞추세요." } },
        "ja"     : { "stringUnit" : { "state" : "translated", "value" : "聴いて、当てよう。" } },
        "zh-Hans": { "stringUnit" : { "state" : "translated", "value" : "听一听，猜一猜。" } },
        "zh-Hant": { "stringUnit" : { "state" : "translated", "value" : "聽聽看，猜一猜。" } },
        "es"     : { "stringUnit" : { "state" : "translated", "value" : "Escúchala. Adivínala." } },
        "pt-BR"  : { "stringUnit" : { "state" : "translated", "value" : "Ouça. Adivinhe." } },
        "id"     : { "stringUnit" : { "state" : "translated", "value" : "Dengarkan. Tebak." } },
        "th"     : { "stringUnit" : { "state" : "translated", "value" : "ฟัง แล้วเดา" } },
        "vi"     : { "stringUnit" : { "state" : "translated", "value" : "Nghe. Đoán." } },
        "fil"    : { "stringUnit" : { "state" : "translated", "value" : "Pakinggan. Hulaan." } },
        "ms"     : { "stringUnit" : { "state" : "translated", "value" : "Dengar. Teka." } },
