    "onboarding.p2.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en"     : { "stringUnit" : { "state" : "translated", "value" : "Type any artist or song to filter suggestions. Wrong guesses with the right artist earn partial credit hints." } },
        "ko"     : { "stringUnit" : { "state" : "translated", "value" : "아티스트나 곡 이름을 입력해 후보를 필터링하세요. 아티스트만 맞춰도 힌트로 인정됩니다." } },
        "ja"     : { "stringUnit" : { "state" : "translated", "value" : "アーティストまたは曲名を入力して候補を絞り込みます。アーティストだけ正解でもヒントとして表示されます。" } },
        "zh-Hans": { "stringUnit" : { "state" : "translated", "value" : "输入艺人或歌名以筛选建议。猜对艺人但歌曲错误会获得部分提示。" } },
        "zh-Hant": { "stringUnit" : { "state" : "translated", "value" : "輸入藝人或歌名以篩選建議。猜對藝人但歌曲錯誤會獲得部分提示。" } },
        "es"     : { "stringUnit" : { "state" : "translated", "value" : "Escribe cualquier artista o canción para filtrar sugerencias. Si aciertas solo el artista, recibes una pista." } },
        "pt-BR"  : { "stringUnit" : { "state" : "translated", "value" : "Digite qualquer artista ou música para filtrar sugestões. Acertar só o artista vira dica parcial." } },
        "id"     : { "stringUnit" : { "state" : "translated", "value" : "Ketik artis atau lagu apa pun untuk menyaring saran. Salah lagu tapi benar artis akan jadi petunjuk." } },
        "th"     : { "stringUnit" : { "state" : "translated", "value" : "พิมพ์ศิลปินหรือเพลงเพื่อกรองตัวเลือก ถ้าทายศิลปินถูกแต่เพลงผิดจะได้รับคำใบ้บางส่วน" } },
        "vi"     : { "stringUnit" : { "state" : "translated", "value" : "Nhập nghệ sĩ hoặc bài hát để lọc gợi ý. Đoán đúng nghệ sĩ nhưng sai bài sẽ được gợi ý một phần." } },
        "fil"    : { "stringUnit" : { "state" : "translated", "value" : "Mag-type ng artist o kanta para mag-filter ng suggestions. Tama sa artist pero mali sa song = partial hint." } },
        "ms"     : { "stringUnit" : { "state" : "translated", "value" : "Taipkan artis atau lagu untuk menapis cadangan. Betul artis tetapi salah lagu akan jadi petunjuk separa." } },
        "hi"     : { "stringUnit" : { "state" : "translated", "value" : "किसी भी कलाकार या गाने को टाइप करके सुझाव फ़िल्टर करें। सही कलाकार लेकिन गलत गाना आंशिक संकेत देता है।" } }
      }
    },
    "onboarding.p3.title" : {
