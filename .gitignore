*.pyc

# macOS
.DS_Store

# Xcode build artifacts
ios/build/
ios/DerivedData/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcuserstate

# Xcode user-specific state (regenerated, OK to ignore)
ios/KPopHeardle.xcodeproj/xcuserdata/
ios/KPopHeardle.xcodeproj/project.xcworkspace/xcuserdata/
ios/KPopHeardle.xcodeproj/project.xcworkspace/xcshareddata/
# NOTE: KPopHeardle.xcodeproj/project.pbxproj IS committed.
# Xcode Cloud validates project existence before running
# ci_scripts/ci_post_clone.sh, so the file must exist in main.
# ci_post_clone.sh still regenerates it from project.yml on every
# Cloud build, so the committed copy stays in sync.

# Intermediate catalog files (kept under data/ as source of truth)
catalog/data/catalog.prev.json

# Xcode user settings
.swiftpm/

# ASC tooling — scripts checked in, but screenshots are large + per-build
asc/screenshots/
asc/screenshots-ipad/
